# Bentabet BSMS — Backend Environment Variables
# Copy this file to .env and fill in production values.

NODE_ENV=production
PORT=5000

# ─── Database ──────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bentabet_db
DB_USER=bentabet
DB_PASSWORD=changeme

# ─── JWT Secrets (generate 64-char hex strings) ───────────────
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=https://bsms.betbenta.com

# ─── Beem Africa SMS ──────────────────────────────────────────
BEEM_API_KEY=
BEEM_SECRET=
BEEM_SENDER_NAME=BENTABET

# ─── Optional ──────────────────────────────────────────────────
# SKIP_SEED=true            # Skip seeder on startup (default: seeds run via findOrCreate)
# RE_SEED_PERMISSIONS=true  # Force re-seed permissions
# UPLOAD_DIR=uploads        # Override upload directory (default: uploads)
